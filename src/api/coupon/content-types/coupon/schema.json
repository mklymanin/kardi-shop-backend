{
  "kind": "collectionType",
  "collectionName": "coupons",
  "info": {
    "singularName": "coupon",
    "pluralName": "coupons",
    "displayName": "Coupon"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true,
      "minLength": 3
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "discountType": {
      "type": "enumeration",
      "enum": ["percent", "fixed"],
      "required": true
    },
    "discountValue": {
      "type": "decimal",
      "required": true
    },
    "startsAt": {
      "type": "datetime"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "description": {
      "type": "text"
    }
  }
}
